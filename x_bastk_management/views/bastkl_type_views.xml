<odoo>

    <record id="view_bastk_type_list" model="ir.ui.view">
        <field name="name">bastk.type.list</field>
        <field name="model">bastk.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>


    <!-- FORM VIEW -->
    <record id="view_bastk_type_form" model="ir.ui.view">
        <field name="name">bastk.type.form</field>
        <field name="model">bastk.type</field>
        <field name="arch" type="xml">
            <form string="BASTK Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_bastk_type" model="ir.actions.act_window">
        <field name="name">BASTK Type</field>
        <field name="res_model">bastk.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_bastk_type"
              name="BASTK Type"
              parent="x_bastk_management.menu_bastk"
              action="action_bastk_type"
              sequence="60"/>
</odoo>