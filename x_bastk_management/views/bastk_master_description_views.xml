<odoo>

    <record id="view_bastk_master_description_list" model="ir.ui.view">
        <field name="name">bastk.master.description.list</field>
        <field name="model">bastk.master.description</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
            </list>
        </field>
    </record>


    <!-- FORM VIEW -->
    <record id="view_bastk_master_description_form" model="ir.ui.view">
        <field name="name">bastk.master.description.form</field>
        <field name="model">bastk.master.description</field>
        <field name="arch" type="xml">
            <form string="BASTK Master Description">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_bastk_master_description" model="ir.actions.act_window">
        <field name="name">BASTK Master Description</field>
        <field name="res_model">bastk.master.description</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_bastk_master_description"
              name="BASTK Master Description"
              parent="x_bastk_management.menu_bastk"
              action="action_bastk_master_description"
              sequence="60"/>
</odoo>