<odoo>
    <record id="view_fleet_vehicle_form_inherit_bastk" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.bastk</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_bastk" type="object" class="oe_stat_button" icon="fa-clipboard">
                    <field name="bastk_count" widget="statinfo" string="BASTK"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
