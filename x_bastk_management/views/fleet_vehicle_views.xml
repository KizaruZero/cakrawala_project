<odoo>
    <record id="view_fleet_vehicle_form_inherit_bastk" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.bastk</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vin_sn']" position="after">
                <field name="engine_number"/>
            </xpath>
        </field>
    </record>
</odoo>
