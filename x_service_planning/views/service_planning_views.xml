<odoo>

    <!-- ===================== -->
    <!-- ACTION -->
    <!-- ===================== -->
    <record id="action_service_planning" model="ir.actions.act_window">
        <field name="name">Service Planning</field>
        <field name="res_model">service.planning</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== -->
    <!-- MENU ROOT -->
    <!-- ===================== -->
    <menuitem id="menu_service_root"
              name="Service Management"
              sequence="10"/>

    <!-- ===================== -->
    <!-- SUB MENU -->
    <!-- ===================== -->
    <menuitem id="menu_service_planning"
              name="Service Planning"
              parent="fleet.menu_root"
              action="action_service_planning"
              sequence="20"/>

    <!-- ===================== -->
    <!-- LIST VIEW (ODDO 19) -->
    <!-- ===================== -->
    <record id="view_service_planning_list" model="ir.ui.view">
        <field name="name">service.planning.list</field>
        <field name="model">service.planning</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- FORM VIEW -->
    <!-- ===================== -->
    <record id="view_service_planning_form" model="ir.ui.view">
        <field name="name">service.planning.form</field>
        <field name="model">service.planning</field>
        <field name="arch" type="xml">
            <form>
                <!-- <header>
                    <button name="action_create_spk"
                            type="object"
                            string="Create SPK"
                            class="btn-primary"/>
                </header> -->
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="asset_number"/>
                            <field name="model_year"/>
                        </group>
                        <group>
                            <field name="license_plate"/>
                            <field name="vin_number"/>
                            <field name="engine_number"/>
                        </group>
                    </group>

                    
                        <field name="line_ids" mode="list,form" nolabel="1" limit="40" pager="true">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="service_part"/>
                                <field name="kilometer"/>
                                <field name="interval"/>
                                <field name="brand_recommendation"/>
                                <field name="remarks"/>
                            </list>
                        </field>
                </sheet>
            </form>
        </field>
    </record>

</odoo>