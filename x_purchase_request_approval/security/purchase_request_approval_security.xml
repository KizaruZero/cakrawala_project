<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record model="ir.rule" id="purchase_request_type_master_company_rule">
        <field name="name">Purchase Request Type Multicompany</field>
        <field name="model_id" search="[('model','=','purchase.request.type.master')]" model="ir.model"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record model="ir.rule" id="purchase_request_approval_config_master_company_rule">
        <field name="name">Purchase Request Approval Config Multicompany</field>
        <field name="model_id" search="[('model','=','purchase.request.approval.config.master')]" model="ir.model"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
