<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Start reject reason -->
        <record id="pr_reject_reason_wizard_form" model="ir.ui.view">
            <field name="name">pr.reject.reason.wizard.form</field>
            <field name="model">pr.reject.reason.wizard</field>
            <field name="arch" type="xml">
                <form string="Warning">
                    <div class="oe_title">
                        <h3>
                            <field name="notes" placeholder="Notes..." required="1"/>
                        </h3>
                    </div>
                    
                    <footer>
                        <button name="action_confirm" string="Confirm" colspan="1" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_pr_reject_reason_wizard" model="ir.actions.act_window">
            <field name="name">Warning</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">pr.reject.reason.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <!-- End reject reason -->

        <!-- Approve reason -->
        <record id="pr_approve_reason_wizard_form" model="ir.ui.view">
            <field name="name">pr.approve.reason.wizard.form</field>
            <field name="model">pr.approve.wizard</field>
            <field name="arch" type="xml">
                <form string="Approve Notes">
                    <div class="oe_title">
                        <h3>
                            <field name="notes" placeholder="Notes..." required="0"/>
                        </h3>
                    </div>

                    <footer>
                        <button name="action_confirm" string="Confirm" colspan="1" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_pr_approve_wizard" model="ir.actions.act_window">
            <field name="name">Approve</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">pr.approve.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>