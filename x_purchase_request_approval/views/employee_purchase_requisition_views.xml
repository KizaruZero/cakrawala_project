<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="purchase_requisition_view_search_custom_approval" model="ir.ui.view">
    <field name="name">purchase.requisition.view.search.custom.approval</field>
    <field name="model">employee.purchase.requisition</field>
    <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_search"/>
    <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
            <field name="name" string="Reference No"
                   filter_domain="[('name', 'ilike', value)]"/>
        </xpath>
    </field>
    </record>

    <record id="employee_purchase_requisition_list_custom_approval" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.list.custom.approval</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="next_approval_sequence"/>
            </xpath>
            <xpath expr="//field[@name='dept_id']" position="replace">
                <field name="department_id" string="Division"/>
            </xpath>
        </field>
    </record>

    <record id="form_employee_purchase_requisition_custom_approval" model="ir.ui.view">
        <field name="name">form.employee.purchase.requisition.custom.approval</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='requisition_order_ids']" position="replace">
                <field name="state" invisible="1"/>
                <field name="requisition_order_ids" readonly="1 if state not in ['new','draft','waiting_department_approval','waiting_head_approval'] else 0">
                    <list editable="bottom" >    
                        <field name="state" column_invisible="True"/>
                        <field name="line_no" column_invisible="True"/>
                        <field name="requisition_type"
                            invisible="state=='new'"
                            column_invisible="True"
                            groups="employee_purchase_requisition.employee_requisition_head,employee_purchase_requisition.employee_requisition_manager"/>
                        <field name="product_id"/>
                        <field name="analytic_distribution" widget="analytic_distribution"/>
                        <field name="description"/>
                        <field name="quantity"/>
                        <field name="ordered_qty" readonly="1"/>
                        <field name="remaining_qty" readonly="1"/>
                        <field name="uom_id"/>
                        <field name="estimate_price"/>
                        <field name="total_price"/>

                        <field name="remark" column_invisible="1"/>
                        <field name="partner_id"
                            column_invisible="1"
                            groups="employee_purchase_requisition.employee_requisition_head,employee_purchase_requisition.employee_requisition_manager"/>
                    </list>
                </field>
                <group>
                    <group class="oe_subtotal_footer">
                        <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget='statusbar' statusbar_visible='draft,waiting_approval,approved,purchase_order_created'/>
            </xpath>

            <xpath expr="//button[@name='action_confirm_requisition']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//button[@name='action_create_purchase_order']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//button[@name='action_receive']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//button[@name='action_create_purchase_order']" position="after">
                <button name="button_submit_requisition" class="oe_highlight" invisible="state != 'draft'"
                    string="Submit" context="{'validate_analytic': True}" type="object" help="Submit to Approval List"/>
                <!-- <button name="button_approve" class="oe_highlight" invisible="state != 'waiting_approval' or is_approver == False"
                    string="Approve" type="object" help="Button Approve"/> -->
                <button name="button_approve_wizard" class="oe_highlight" invisible="state != 'waiting_approval' or is_approver == False"
                    string="Approve" type="object" help="Button Approve"/>
                <button name="button_reject_wizard" invisible="state != 'waiting_approval' or is_approver == False"
                    string="Reject" type="object" help="Button Reject"/>
                <button name="button_revise" invisible="state not in ['rejected'] or is_user_creator == False"
                    string="Revise" type="object" help="Button Revise"/>
                <!-- <button name="button_create_purchase_order" class="oe_highlight"
                    invisible="state not in ['approved','purchase_order_created'] or is_po_has_approve == True"
                    string="Create RFQ" type="object" help="Create Requests for Quotation"
                    groups="x_purchase_request_approval.group_create_po_from_pr"/> -->
            </xpath>

            <xpath expr="//field[@name='employee_id']" position="before">
                <field name="partner_id" readonly="state not in ['new','draft']"
                    options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
                <field name="purchase_request_type_id" readonly="state not in ['new','draft']" required="1"
                    options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
                <field name="department_id" readonly="state not in ['new','draft']"
                    options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
                <field name="create_uid" readonly="1" force_save="1" string="Created By"
                    options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
            </xpath>

            <xpath expr="//field[@name='dept_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='employee_id']" position="attributes">
                <attribute name="string">Request By</attribute>
                <attribute name="readonly">state not in ['new','draft']</attribute>
                <attribute name="options">{'no_create_edit': True, 'no_create': True, 'no_open': True}</attribute>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
                <attribute name="readonly">state not in ['new','draft']</attribute>
                <attribute name="options">{'no_create_edit': True, 'no_create': True, 'no_open': True}</attribute>
            </xpath>

            <xpath expr="//field[@name='receive_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='requisition_date']" position="attributes">
                <attribute name="readonly">state not in ['new','draft']</attribute>
                <attribute name="options">{'no_create_edit': True, 'no_create': True, 'no_open': True}</attribute>
            </xpath>

            <xpath expr="//field[@name='requisition_deadline']" position="before">
                <field name="internal_reference" readonly="state not in ['new','draft']" required="1"/>
                <field name="description" readonly="state not in ['new','draft']"/>
                <field name="currency_id" readonly="state not in ['new','draft']"
                    options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
                <field name="is_approver" readonly="1" invisible="1"/>
                <field name="is_user_creator" readonly="1" invisible="1"/>
                <field name="is_po_has_approve" readonly="1" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='source_location_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='destination_location_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='internal_picking_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='requisition_description']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- <xpath expr="//field[@name='requisition_order_ids']" position="replace">
                <field name="requisition_order_ids" readonly="1 if state not in ['new','draft'] else 0"/>
                <group>
                    <group class="oe_subtotal_footer">
                        <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                    </group>
                </group>
            </xpath> -->

            <xpath expr="//page[1]" position="after">
                <page string="Approval Matrix">
                    <field name="purchase_requisition_approver_matrix_ids" readonly="1">
                        <list string="Approval Matrix">
                            <field name="employee_purchase_requisition_id" column_invisible="1"/>
                            <field name="sequence"/>
                            <field name="approver_id"/>
                            <field name="delegation_id"/>
                            <field name="actual_approver_id"/>
                            <field name="state"/>
                            <field name="date_approved"/>
                            <field name="date_rejected"/>
                            <field name="start_valid" optional="hide"/>
                            <field name="valid_until" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <xpath expr="//page[4]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>