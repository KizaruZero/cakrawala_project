<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_inherit_purchase_approval" model="ir.ui.view">
        <field name="name">product.template.form.inherit.purchase.approval</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='invoicing']" position="after">
                <page string="Sparepart Information" name="sparepart_information">
                    <group name="sparepart_information_group">
                        <group name="sparepart_information_group_left">
                            <field name="product_maker"/>
                            <field name="product_type"/>
                            <field name="product_dwg_number"/>
                        </group>
                        <group name="sparepart_information_group_left">
                            <field name="product_fin_plan"/>
                            <field name="product_serial_number"/>
                            <field name="product_part_no"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>