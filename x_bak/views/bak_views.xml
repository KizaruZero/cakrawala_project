<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- ACTION -->
    <!-- ===================== -->
    <record id="action_bak" model="ir.actions.act_window">
        <field name="name">BAK</field>
        <field name="res_model">bak</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== -->
    <!-- MENU -->
    <!-- ===================== -->
    <menuitem id="bak_menu_root" name="BAK" parent="fleet.menu_root" sequence="110"/>
    <menuitem id="bak_menu_operations" name="Operations" parent="bak_menu_root" sequence="10"/>
    <menuitem id="bak_menu_bak" name="BAK" action="action_bak" parent="bak_menu_operations" sequence="1"/>

    <menuitem id="bak_menu_fleet" name="Fleet" parent="bak_menu_operations" sequence="2"/>
    <menuitem id="bak_menu_vehicle" name="Vehicles" action="fleet.fleet_vehicle_action" parent="bak_menu_fleet" sequence="1"/>

    <!-- ===================== -->
    <!-- LIST VIEW -->
    <!-- ===================== -->
    <record id="view_bak_list" model="ir.ui.view">
        <field name="name">bak.list</field>
        <field name="model">bak</field>
        <field name="arch" type="xml">
            <list string="Berita Acara Kejadian">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_model_id"/>
                <field name="vehicle_id"/>
                <field name="state" widget="badge" decoration-success="state in ('submitted', 'done')"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- FORM VIEW -->
    <!-- ===================== -->
    <record id="view_bak_form" model="ir.ui.view">
        <field name="name">bak.form</field>
        <field name="model">bak</field>
        <field name="arch" type="xml">
            <form string="Berita Acara Kejadian">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_create_spk" type="object" string="Create SPK" class="btn-primary" invisible="state != 'submitted'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="driver_name"/>
                            <field name="address"/>
                            <field name="phone"/>
                            <field name="currency_id"/>
                            <field name="cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="vehicle_model_id"/>
                            <field name="vehicle_id"/>
                            <field name="year"/>
                            <field name="last_odometer"/>
                            <field name="ticket_number"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Detail" name="detail">
                            <field name="incident_line_ids" mode="list" string="Tanggal Kejadian">
                                <list editable="bottom">
                                    <field name="incident_date"/>
                                    <field name="location"/>
                                    <field name="chronology"/>
                                </list>
                            </field>
                            <br/>
                            <field name="damage_line_ids" mode="list" string="Bagian/Komponen yang rusak/hilang">
                                <list editable="bottom">
                                    <field name="damage"/>
                                    <field name="attachment" filename="attachment_name" widget="binary"/>
                                    <field name="attachment_name" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Enter internal notes here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
