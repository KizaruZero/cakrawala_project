<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Approval Matrix List View -->
    <record id="spk_approval_matrix_tree" model="ir.ui.view">
      <field name="name">spk.approval.matrix.tree</field>
      <field name="model">spk.approval.matrix</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="is_default" widget="boolean_toggle"/>
          <field name="category"/>
          <field name="maintenance_type_id"/>
          <field name="active" widget="boolean_toggle"/>
        </list>
      </field>
    </record>

    <!-- Approval Matrix Form View -->
    <record id="spk_approval_matrix_form" model="ir.ui.view">
      <field name="name">spk.approval.matrix.form</field>
      <field name="model">spk.approval.matrix</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" readonly="1"/>
              </h1>
              <div invisible="not is_default">
                <span class="badge text-bg-info">DEFAULT RULE</span>
              </div>
            </div>

            <group>
              <group>
                <field name="active"/>
                <field name="is_default"/>
                <field name="category" required="1"/>
                <field name="maintenance_type_id" required="not is_default"
                       invisible="is_default"
                       help="Required for specific (non-default) matrices."/>
              </group>
            </group>

            <separator string="Approval Sequence"/>
            <p class="text-muted fst-italic">
              Define multi-level approvers. Each line represents one approval level.
              Levels are activated by the <strong>Starting Amount</strong> threshold:
              if SPK amount &gt;= starting amount, that level is required.
            </p>

            <field name="approval_line_ids">
              <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="sequence" string="No." readonly="1"/>
                <field name="approver_id" required="1"/>
                <field name="delegate_id"/>
                <field name="delegate_valid_from"/>
                <field name="delegate_valid_to"/>
                <field name="starting_amount"/>
                <field name="currency_id" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
              </list>
            </field>

            <separator string="Info"/>
            <p class="text-muted">
              <strong>Default Rule:</strong> Used as fallback when no specific rule matches the SPK criteria.<br/>
              <strong>Starting Amount (Threshold):</strong> Approver is triggered when SPK amount &gt;= this value.<br/>
              <strong>Delegate:</strong> Can approve on behalf of the Approver during the delegation validity period.<br/>
              <strong>Valid From / To:</strong> This line is only active within the specified date range.
            </p>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Approval Matrix Search View -->
    <record id="spk_approval_matrix_search" model="ir.ui.view">
      <field name="name">spk.approval.matrix.search</field>
      <field name="model">spk.approval.matrix</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="category"/>
          <field name="maintenance_type_id"/>
          <separator/>
          <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
          <filter name="filter_inactive" string="Inactive" domain="[('active', '=', False)]"/>
          <filter name="filter_default" string="Default Rules" domain="[('is_default', '=', True)]"/>
          <separator/>
          <filter name="group_by_category" string="Category" context="{'group_by': 'category'}"/>
          <filter name="group_by_maintenance_type" string="Maintenance Type" context="{'group_by': 'maintenance_type_id'}"/>
        </search>
      </field>
    </record>

    <!-- Approval Matrix Window Action -->
    <record id="spk_approval_matrix_action" model="ir.actions.act_window">
      <field name="name">Approval Matrix</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">spk.approval.matrix</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Create a new Approval Matrix
        </p>
        <p>
          Configure approval workflows by defining which users approve SPKs based on:<br/>
          - Category (Internal / External)<br/>
          - Maintenance Type<br/>
          - Starting Amount (threshold-based multi-level approval)
        </p>
      </field>
    </record>

  </data>
</odoo>
