<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Product Template Form Extension -->
    <record id="product_template_form_inherit_x_spk" model="ir.ui.view">
      <field name="name">product.template.form.inherit.x_spk</field>
      <field name="model">product.template</field>
      <field name="inherit_id" ref="product.product_template_form_view"/>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='general_information']//group/group[1]" position="inside">
          <separator string="SPK"/>
          <field name="is_tyre"/>
          <field name="is_aki"/>
          <field name="is_on_risk"/>
        </xpath>
      </field>
    </record>

    <!-- Product Template Search View Extension -->
    <record id="product_template_search_inherit_x_spk" model="ir.ui.view">
      <field name="name">product.template.search.inherit.x_spk</field>
      <field name="model">product.template</field>
      <field name="inherit_id" ref="product.product_template_search_view"/>
      <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
          <separator/>
          <filter name="is_tyre" string="Tyre" domain="[('is_tyre', '=', True)]"/>
          <filter name="is_aki" string="AKI (Battery)" domain="[('is_aki', '=', True)]"/>
          <filter name="is_on_risk" string="On Risk" domain="[('is_on_risk', '=', True)]"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
