<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- SPK Tree View -->
    <record id="fleet_spk_tree" model="ir.ui.view">
      <field name="name">fleet.spk.tree</field>
      <field name="model">fleet.spk</field>
      <field name="arch" type="xml">
        <list string="SPK">
          <field name="name"/>
          <field name="state"/>
          <field name="vehicle_id"/>
          <field name="license_plate"/>
          <field name="maintenance_type_id"/>
          <field name="category"/>
          <field name="spk_date"/>
          <field name="total_amount"/>
        </list>
      </field>
    </record>

    <!-- SPK Search View -->
    <record id="fleet_spk_search" model="ir.ui.view">
      <field name="name">fleet.spk.search</field>
      <field name="model">fleet.spk</field>
      <field name="arch" type="xml">
        <search string="SPK">
          <field name="name"/>
          <field name="vehicle_id"/>
          <field name="license_plate"/>
          <field name="vendor_id"/>
          <separator/>
          <filter name="new" string="New" domain="[('state', '=', 'new')]"/>
          <filter name="waiting_approval" string="Waiting Approval" domain="[('state', '=', 'waiting_approval')]"/>
          <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
          <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
          <filter name="rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
          <separator/>
          <filter name="internal" string="Internal" domain="[('category', '=', 'internal')]"/>
          <filter name="external" string="External" domain="[('category', '=', 'external')]"/>
          <separator/>
          <filter name="emergency" string="Emergency" domain="[('maintenance_type', '=', 'emergency')]"/>
          <filter name="accident" string="Accident" domain="[('maintenance_type', '=', 'accident')]"/>
          <separator/>
          <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
          <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
          <filter name="group_maintenance_type" string="Maintenance Type" context="{'group_by': 'maintenance_type'}"/>
        </search>
      </field>
    </record>

    <!-- SPK Form View -->
    <record id="fleet_spk_form" model="ir.ui.view">
      <field name="name">fleet.spk.form</field>
      <field name="model">fleet.spk</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <!-- <button name="action_open_tyre_aki_wizard" string="Fill Tyre/AKI Details" type="object" class="btn-info" invisible="state != 'draft'"/> -->
            <button name="action_submit_for_approval" string="Submit for Approval" type="object" class="btn-primary" invisible="state != 'draft'"/>
            <button name="action_open_accept_wizard" string="Approve" type="object" class="btn-success" invisible="not can_current_user_approve"/>
            <button name="action_open_reject_wizard" string="Reject" type="object" class="btn-danger" invisible="not can_current_user_approve"/>
            <button name="action_done" string="Done" type="object" class="btn-primary" invisible="state != 'approved'"/>
            <button name="action_received" string="Invoice Received" type="object" class="btn-secondary" invisible="state != 'done'"/>
            <field name="can_current_user_approve" invisible="1"/>
            <field name="can_current_user_delegate" invisible="1"/>
            <field name="state" widget="statusbar" statusbar_visible="new,waiting_approval,approved,done,rejected,received"/>
          </header>
          <sheet>
            <group>
              <!-- Kolom kiri -->
              <group>
                <field name="name" readonly="1" force_save="1"/>
                <field name="execution_type_id" required="1" readonly="state in ['approved', 'received']"/>
                <field name="category" required="1" readonly="state in ['approved', 'received']"/>
                <field name="maintenance_type_id" required="1" readonly="state in ['approved', 'received']"/>
                <field name="vendor_id" invisible="category != 'external'" readonly="state in ['approved', 'received']"/>
                <field name="customer_id" readonly="state in ['approved', 'received']"/>
                <field name="pic_client" readonly="state in ['approved', 'received']"/>
                <field name="bak_id" readonly="state in ['approved', 'received']"/>
                <field name="goods_issue_source_id" invisible="category != 'internal'" readonly="state in ['approved', 'received']"/>
                <field name="description" placeholder="Description..." readonly="state in ['approved', 'received']"/>
                <field name="currency_id" readonly="state in ['approved', 'received']"/>
              </group>
              <!-- Kolom kanan -->
              <group>
                <field name="spk_date" readonly="state in ['approved', 'received']"/>
                <field name="planning_date" readonly="state in ['approved', 'received']"/>
                <field name="vehicle_id" required="1" readonly="state in ['approved', 'received']"/>
                <field name="next_approver_id" readonly="1"/>
                <field name="license_plate" readonly="1" force_save="1"/>
                <field name="color" readonly="1" force_save="1"/>
                <field name="year" readonly="1" force_save="1"/>
                <field name="vin_sn" readonly="1" force_save="1"/>
                <field name="engine_number" readonly="1" force_save="1"/>
                <field name="odometer" nolabel="0" force_save="1" readonly="state in ['approved', 'received']"/>
                <span> km</span>
                <field name="last_service" readonly="1" force_save="1"/>
              </group>
            </group>

            <notebook>
              <!-- Product Sparepart Tab -->
              <page string="Product Sparepart" name="sparepart" invisible="maintenance_type == 'accident'">
                <field name="sparepart_line_ids" readonly="state in ['approved', 'received']">
                  <list editable="bottom">
                    <field name="product_id" domain="[('type', '=', 'consu')]"/>
                    <field name="description"/>
                    <field name="analytic_account_id"/>
                    <field name="quantity"/>
                    <field name="product_uom_id"/>
                    <field name="tax_ids" widget="many2many_tags"/>
                    <field name="unit_price"/>
                    <field name="subtotal_without_tax" readonly="1" sum="Total (before tax)"/>
                    <field name="tax_total" readonly="1" sum="Total Tax"/>
                    <field name="subtotal" readonly="1" sum="Total (with tax)"/>
                  </list>
                </field>
                <group class="oe_subtotal_footer">
                  <field name="total_sparepart_amount" readonly="1" class="oe_subtotal_footer_separator"/>
                </group>
              </page>

              <!-- Product Service Tab -->
              <page string="Product Service" name="service" invisible="maintenance_type == 'accident'">
                <field name="service_line_ids" readonly="state in ['approved', 'received']">
                  <list editable="bottom">
                    <field name="product_id" domain="[('type', '=', 'service')]"/>
                    <field name="quantity"/>
                    <field name="unit_price"/>
                    <field name="subtotal" readonly="1"/>
                  </list>
                </field>
                <group class="oe_subtotal_footer">
                  <field name="total_service_amount" readonly="1" class="oe_subtotal_footer_separator"/>
                </group>
              </page>

              <!-- Products On Risk Tab (only for Accident) -->
              <page string="Products On Risk" name="on_risk" invisible="maintenance_type != 'accident'">
                <field name="on_risk_product_ids" readonly="state in ['approved', 'received']">
                  <list editable="bottom">
                    <field name="product_id" domain="[('is_on_risk', '=', True)]"/>
                    <field name="quantity"/>
                    <field name="unit_price"/>
                    <field name="description"/>
                    <field name="subtotal" readonly="1"/>
                  </list>
                </field>
                <group class="oe_subtotal_footer">
                  <field name="total_amount" readonly="1" class="oe_subtotal_footer_separator"/>
                </group>
              </page>

              <!-- Tyre Detail Tab -->
              <page string="Tyre Detail" name="tyre_detail">
                <field name="tyre_detail_ids" readonly="state in ['approved', 'received']">
                  <list editable="bottom">
                    <field name="product_description" readonly="1"/>
                    <field name="old_production_number"/>
                    <field name="new_production_number"/>
                    <field name="notes"/>
                  </list>
                </field>
              </page>

              <!-- AKI Detail Tab -->
              <page string="AKI Detail" name="aki_detail">
                <field name="aki_detail_ids" readonly="state in ['approved', 'received']">
                  <list editable="bottom">
                    <field name="product_description" readonly="1"/>
                    <field name="old_AKI_code"/>
                    <field name="new_AKI_code"/>
                    <field name="notes"/>
                  </list>
                </field>
              </page>

              <!-- Approval Tracking Tab -->
              <page string="Approval Tracking" name="approvals">
                <field name="approval_tracking_ids" readonly="1">
                  <list
                    decoration-warning="state == 'pending'"
                    decoration-success="state == 'approved'"
                    decoration-danger="state == 'rejected'"
                    decoration-muted="state == 'cancelled'">
                    <field name="sequence"/>
                    <field name="approver_id"/>
                    <field name="delegate_id"/>
                    <field name="delegate_valid_from"/>
                    <field name="delegate_valid_to"/>
                    <field name="state"/>
                    <field name="date"/>
                    <field name="remarks"/>
                  </list>
                </field>
              </page>
            </notebook>

            <group>
              <group>
                <field name="total_sparepart_amount" readonly="1" invisible="maintenance_type == 'accident'"/>
                <field name="total_service_amount" readonly="1" invisible="maintenance_type == 'accident'"/>
              </group>
              <group>
                <field name="total_amount" readonly="1"/>
                <field name="po_id" readonly="1"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- SPK Action -->
    <record id="fleet_spk_action" model="ir.actions.act_window">
      <field name="name">SPK (Surat Perintah Kerja)</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">fleet.spk</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
                    Create a new SPK (Surat Perintah Kerja)
        </p>
      </field>
    </record>
  </data>
</odoo>
