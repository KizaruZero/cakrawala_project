<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Execution Type Views -->
    <record id="spk_execution_type_tree" model="ir.ui.view">
      <field name="name">spk.execution.type.tree</field>
      <field name="model">spk.execution.type</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence" widget="handle"/>
          <field name="name"/>
          <field name="code"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="spk_execution_type_form" model="ir.ui.view">
      <field name="name">spk.execution.type.form</field>
      <field name="model">spk.execution.type</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="spk_execution_type_action" model="ir.actions.act_window">
      <field name="name">Execution Type</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">spk.execution.type</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Maintenance Type Views -->
    <record id="spk_maintenance_type_tree" model="ir.ui.view">
      <field name="name">spk.maintenance.type.tree</field>
      <field name="model">spk.maintenance.type</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence" widget="handle"/>
          <field name="name"/>
          <field name="code"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="spk_maintenance_type_form" model="ir.ui.view">
      <field name="name">spk.maintenance.type.form</field>
      <field name="model">spk.maintenance.type</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="spk_maintenance_type_action" model="ir.actions.act_window">
      <field name="name">Maintenance Type</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">spk.maintenance.type</field>
      <field name="view_mode">list,form</field>
    </record>
  </data>
</odoo>
