<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Fleet Vehicle Form View Extension -->
    <record id="fleet_vehicle_form_inherit" model="ir.ui.view">
      <field name="name">fleet.vehicle.form.inherit</field>
      <field name="model">fleet.vehicle</field>
      <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
          <button name="%(fleet_spk_action)d" type="action" class="oe_stat_button" icon="fa-wrench" context="{'search_default_vehicle_id': id, 'default_vehicle_id': id}">
            <field name="spk_count" widget="statinfo" string="SPK"/>
          </button>
        </xpath>
        <xpath expr="//form/sheet/notebook" position="inside">
          <page string="Tyre History" name="tyre_history">
            <field name="tyre_history_ids" readonly="1">
              <list>
                <field name="product_description"/>
                <field name="spk_number"/>
                <field name="date"/>
                <field name="old_production_number"/>
                <field name="new_production_number"/>
                <field name="notes"/>
              </list>
            </field>
          </page>
          <page string="AKI History" name="aki_history">
            <field name="aki_history_ids" readonly="1">
              <list>
                <field name="product_description"/>
                <field name="spk_number"/>
                <field name="date"/>
                <field name="old_AKI_code"/>
                <field name="new_AKI_code"/>
                <field name="notes"/>
              </list>
            </field>
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
