<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- Approval Role Master Data -->
    <record id="approval_role_manager" model="res.groups.approval.role">
      <field name="name">Manager</field>
      <field name="sequence">1</field>
      <field name="description">Level 1 (Manager) - Responsible for initial approval of service and maintenance requests</field>
      <field name="active">True</field>
    </record>

    <record id="approval_role_senior_manager" model="res.groups.approval.role">
      <field name="name">Senior Manager</field>
      <field name="sequence">2</field>
      <field name="description">Level 2 (Senior Manager) - Secondary approval level for escalated or higher value requests</field>
      <field name="active">True</field>
    </record>

    <record id="approval_role_director" model="res.groups.approval.role">
      <field name="name">Director</field>
      <field name="sequence">3</field>
      <field name="description">Level 3 (Director) - Final approval authority for critical or high-value requests</field>
      <field name="active">True</field>
    </record>
  </data>
</odoo>
