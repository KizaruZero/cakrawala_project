<odoo>
    <data>
        <record id="employee_purchase_requisition_rule_multi_company" model="ir.rule">
            <field name="name">Employee Purchase Requisition: Multi Company</field>
            <field name="model_id" ref="employee_purchase_requisition.model_employee_purchase_requisition"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="employee_purchase_requisition_line_rule_multi_company" model="ir.rule">
            <field name="name">Employee Purchase Requisition Line: Multi Company</field>
            <field name="model_id" ref="employee_purchase_requisition.model_requisition_order"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="employee_purchase_requisition_line_company_rule" model="ir.rule">
            <field name="name">Purchase Requisition Line Company Rule</field>
            <field ref="model_requisition_order" name="model_id"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>