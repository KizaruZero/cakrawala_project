<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="requisition_order_list_custom_approval_create_po" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.custom.approval.create.po</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_create_purchase_order']" position="after">
                <button name="button_create_purchase_order" class="oe_highlight"
                    invisible="state not in ['approved','purchase_order_created'] or is_po_has_approve == True or not active_create_po"
                    string="Create RFQ" type="object" help="Create Requests for Quotation"
                    groups="x_purchase_request_approval.group_create_po_from_pr"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Debug Create RFQ Visibility" groups="base.group_system">
                    <field name="state" readonly="1"/>
                    <field name="is_po_has_approve" readonly="1"/>
                    <field name="active_create_po" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_employee_purchase_requisition_search_inherit" model="ir.ui.view">
    <field name="name">employee.purchase.requisition.search.inherit</field>
    <field name="model">employee.purchase.requisition</field>
    <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_search"/>
    <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
            <separator/>
            <filter string="Archived"
                    name="archived"
                    domain="[('active', '=', False)]"/>
            <filter string="Unarchived"
                    name="unarchived"
                    domain="[('active', '=', True)]"/>
        </xpath>
    </field>
    </record>

    <record id="employee_purchase_requisition_view_tree_inherit_create_po" model="ir.ui.view">
        <field name="name">employee.purchase.requisition.view.tree.inherit.create.po</field>
        <field name="model">employee.purchase.requisition</field>
        <field name="inherit_id" ref="employee_purchase_requisition.employee_purchase_requisition_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="purchase_order_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="requisition_order_item_list" model="ir.ui.view">
        <field name="name">requisition.order.item.list</field>
        <field name="model">requisition.order</field>
        <field name="arch" type="xml">
            <list string="Purchase Request Lines" create="false" edit="false" delete="false">
                <header>
                    <button name="action_open_pr_create_po_wizard" class="oe_highlight"
                        string="Create Purchase Order"
                        type="object"
                        groups="x_purchase_request_create_po.group_create_po_from_pr_line"
                    />
                </header>
                <field name="requisition_product_id"/>
                <field name="partner_id"/>
                <field name="department_id"/>
                <field name="product_id"/>
                <field name="purchase_request_type_id"/>
                <field name="quantity" string="PR Quantity"/>
                <field name="ordered_qty" string="Ordered Quantity"/>
                <field name="remaining_qty" string="Remaining Quantity"/>
                <!-- <field name="outstanding_qty" string="Outstanding Quantity"/> -->
                <field name="company_id"/>
                <field name="purchase_ids" widget="many2many_tags" column_invisible="0"/>
            </list>
        </field>
    </record>

    <record id="requisition_order_view_search" model="ir.ui.view">
        <field name="name">requisition.order.view.search</field>
        <field name="model">requisition.order</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <filter string="Unarchived" name="unarchived" domain="[('active', '=', True)]"/>
                <separator/>
                <filter string="Group By Purchase Requisition"
                        name="group_by_purchase_requisition"
                        context="{'group_by': 'requisition_product_id'}"/>
            </search>
        </field>
    </record>
    
    <record id="action_requisition_order_item_list" model="ir.actions.act_window">
        <field name="name">Purchase Request Lines</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">requisition.order</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="requisition_order_item_list"/>
        <field name="domain">[('state','in', ['approved', 'purchase_order_created'])] </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record!
            </p>
        </field>
    </record>
</odoo>